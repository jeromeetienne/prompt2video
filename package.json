{
    "name": "prompt2video",
    "version": "1.0.4",
    "description": "Promptable, AI-automated video generator: give a prompt, Claude Code drives Remotion to produce a narrated MP4 + slides PDF.",
    "bin": {
        "prompt2video": "dist/cli.js"
    },
    "main": "dist/cli.js",
    "types": "dist/cli.d.ts",
    "engines": {
        "node": ">=20.12"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "tsc -p tsconfig.build.json",
        "install-skill": "tsx ./src/cli.ts install",
        "video:build": "tsx ./src/cli.ts build",
        "publish:all": "npm run build && npm version patch && npm publish"
    },
    "keywords": [
        "claude",
        "claude-code",
        "remotion",
        "video",
        "ai",
        "prompt",
        "automation",
        "voice-over",
        "cli"
    ],
    "author": "Jerome Etienne <jerome.etienne@gmail.com>",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jeromeetienne/prompt2video.git"
    },
    "homepage": "https://github.com/jeromeetienne/prompt2video#readme",
    "bugs": {
        "url": "https://github.com/jeromeetienne/prompt2video/issues"
    },
    "files": [
        "dist",
        "skills",
        "LICENSE",
        "README.md"
    ],
    "devDependencies": {
        "@types/node": "^20.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "commander": "^14.0.3"
    }
}
